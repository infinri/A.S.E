# A.S.E. Configuration
# Copy to .env and fill in values

# Feeds to enable (comma-separated: kev,nvd,ghsa,osv,packagist)
ENABLED_FEEDS=kev,nvd,ghsa,osv,packagist

# API keys
NVD_API_KEY=
GITHUB_TOKEN=

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../xxxx
SLACK_CHANNEL_CRITICAL=#security-critical
SLACK_CHANNEL_ALERTS=#security-alerts

# Poll intervals in seconds
POLL_INTERVAL_KEV=7200
POLL_INTERVAL_NVD=7200
POLL_INTERVAL_GHSA=1800
POLL_INTERVAL_OSV=1800
POLL_INTERVAL_PACKAGIST=3600

# Ecosystem filtering
ECOSYSTEMS=composer,npm
VENDOR_FILTER=adobe,magento
NVD_CPE_PREFIX=cpe:2.3:a:adobe:commerce

# Composer.lock cross-reference (optional, leave empty to skip)
COMPOSER_LOCK_PATH=

# State and logging
STATE_FILE=var/state/state.json
LOG_FILE=var/log/ase.log
HEARTBEAT_FILE=var/run/last_success.txt

# Priority thresholds
EPSS_HIGH_THRESHOLD=0.10
EPSS_MEDIUM_THRESHOLD=0.05
CVSS_CRITICAL_THRESHOLD=9.0
CVSS_HIGH_THRESHOLD=7.0
CVSS_MEDIUM_THRESHOLD=4.0

# Initial backfill window (days)
BACKFILL_DAYS=30
