# A.S.E. Configuration
# Copy to .env and fill in values

# Feeds to enable (comma-separated: kev,nvd,ghsa,osv,packagist)
ENABLED_FEEDS=kev,nvd,ghsa,osv,packagist

# API keys
NVD_API_KEY=
GITHUB_TOKEN=

# Slack -- P0 (always-on) webhook. Required for notifications.
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../xxxx

# Slack -- P1 webhook. Optional. When set, P1 alerts route here.
# When unset, P1 alerts are silently skipped (a single warning is logged per run).
SLACK_WEBHOOK_P1=

# Poll intervals in seconds
POLL_INTERVAL_KEV=7200
POLL_INTERVAL_NVD=7200
POLL_INTERVAL_GHSA=1800
POLL_INTERVAL_OSV=1800
POLL_INTERVAL_PACKAGIST=3600

# Ecosystem filtering (optional -- auto-detected from composer.lock)
# These are ADDITIVE: the auto-detected values (composer + vendors parsed from
# composer.lock) are merged with whatever you set here. Only fill these in when
# you need to track something that isn't in your composer.lock.
ECOSYSTEMS=
VENDOR_FILTER=
# NVD_CPE_PREFIX is a single value and OVERRIDES auto-detection when set.
# Auto-detection maps Magento edition -> CPE:
#   magento-community  -> cpe:2.3:a:magento:magento
#   magento-enterprise -> cpe:2.3:a:adobe:commerce
NVD_CPE_PREFIX=

# Composer.lock cross-reference (optional -- ASE walks up from CWD automatically)
COMPOSER_LOCK_PATH=

# State and logging
STATE_FILE=var/state/state.json
LOG_FILE=var/log/ase.log
HEARTBEAT_FILE=var/run/last_success.txt

# Priority thresholds
EPSS_HIGH_THRESHOLD=0.10
CVSS_CRITICAL_THRESHOLD=9.0
CVSS_HIGH_THRESHOLD=7.0

# Initial backfill window (days)
BACKFILL_DAYS=30
