{
    "name": "2ndswing/ase",
    "description": "Automated Security Evaluator - lightweight vulnerability monitoring",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.4",
        "composer/semver": "^3.4",
        "monolog/monolog": "^3.10",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.1",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "Ase\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ase\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
